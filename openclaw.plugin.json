{
  "id": "algo-memory",
  "name": "algo-memory",
  "description": "纯算法长期记忆插件 - 0 API，可选 LLM 增强",
  "version": "1.0.0",
  "kind": "memory",
  "homepage": "https://github.com/xcqblue/algo-memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "autoCapture": {
        "type": "boolean",
        "default": true,
        "description": "自动捕获对话中的记忆"
      },
      "autoRecall": {
        "type": "boolean",
        "default": true,
        "description": "自动召回相关记忆"
      },
      "maxResults": {
        "type": "number",
        "default": 5,
        "description": "召回结果数量"
      },
      "cleanupDays": {
        "type": "number",
        "default": 180,
        "description": "清理超过此天数的无用记忆"
      },
      "recencyDecay": {
        "type": "boolean",
        "default": true,
        "description": "启用时间衰减"
      },
      "recencyHalfLife": {
        "type": "number",
        "default": 180,
        "description": "记忆半衰期(天)"
      },
      "smartDedup": {
        "type": "boolean",
        "default": true,
        "description": "启用智能去重"
      },
      "dedupThreshold": {
        "type": "number",
        "default": 0.85,
        "description": "去重阈值"
      },
      "coreKeywords": {
        "type": "array",
        "items": { "type": "string" },
        "description": "核心记忆关键词"
      },
      "llm": {
        "type": "object",
        "description": "LLM 配置 (可选)",
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "provider": { "type": "string", "default": "openai" },
          "apiKey": { "type": "string", "default": "" },
          "model": { "type": "string", "default": "gpt-4o-mini" },
          "baseURL": { "type": "string", "default": "https://api.openai.com/v1" }
        }
      },
      "threshold": {
        "type": "object",
        "description": "LLM 阈值配置",
        "properties": {
          "useLlmForCore": { "type": "boolean", "default": false, "description": "用LLM判断是否核心记忆" },
          "useLlmForExtract": { "type": "boolean", "default": false, "description": "用LLM提取关键词" },
          "useLlmForDedup": { "type": "boolean", "default": false, "description": "用LLM判断是否重复" },
          "minConfidence": { "type": "number", "default": 0.8, "description": "最低置信度" }
        }
      }
    }
  },
  "requirements": {
    "node": ">=18.0.0",
    "openclaw": ">=2026.2.0"
  }
}
