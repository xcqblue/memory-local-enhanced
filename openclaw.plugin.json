{
  "id": "algo-memory",
  "name": "algo-memory",
  "description": "纯算法长期记忆插件 - 0 API / 可选 LLM 增强",
  "version": "1.0.0",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "properties": {
      "autoCapture": {
        "type": "boolean",
        "default": true,
        "description": "自动捕获对话中的记忆"
      },
      "autoRecall": {
        "type": "boolean",
        "default": true,
        "description": "自动召回相关记忆"
      },
      "maxResults": {
        "type": "number",
        "default": 5,
        "description": "召回结果数量"
      },
      "cleanupDays": {
        "type": "number",
        "default": 180,
        "description": "清理超过此天数的无用记忆"
      },
      "recencyDecay": {
        "type": "boolean",
        "default": true,
        "description": "启用时间衰减"
      },
      "recencyHalfLife": {
        "type": "number",
        "default": 180,
        "description": "记忆半衰期(天)"
      }
    }
  }
}
