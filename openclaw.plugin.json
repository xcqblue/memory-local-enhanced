{
  "id": "algo-memory",
  "name": "algo-memory",
  "description": "纯算法长期记忆插件 - 0 API，完全本地运行，无需网络",
  "version": "1.0.0",
  "kind": "memory",
  "homepage": "https://github.com/xcqblue/algo-memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "autoCapture": {
        "type": "boolean",
        "default": true,
        "description": "自动捕获对话中的记忆"
      },
      "autoRecall": {
        "type": "boolean",
        "default": true,
        "description": "自动召回相关记忆"
      },
      "maxResults": {
        "type": "number",
        "default": 5,
        "description": "召回结果数量"
      },
      "cleanupDays": {
        "type": "number",
        "default": 180,
        "description": "清理超过此天数的无用记忆"
      },
      "recencyDecay": {
        "type": "boolean",
        "default": true,
        "description": "启用时间衰减"
      },
      "recencyHalfLife": {
        "type": "number",
        "default": 180,
        "description": "记忆半衰期(天)"
      },
      "coreKeywords": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["记住", "牢记", "重要", "remember", "important"],
        "description": "自动识别为核心记忆的关键词"
      }
    }
  },
  "requirements": {
    "node": ">=18.0.0",
    "openclaw": ">=2026.2.0"
  },
  "setup": {
    "notes": [
      "安装后，在 ~/.openclaw/openclaw.json 中添加配置",
      "将 algo-memory 添加到 plugins.allow 列表",
      "设置 plugins.slots.memory = 'algo-memory' (如果要与 memos 共存，需要修改配置)",
      "重启 Gateway: openclaw gateway restart",
      "如果 better-sqlite3 编译失败，确保已安装 C++ 构建工具"
    ]
  }
}
