{
  "id": "algo-memory",
  "name": "algo-memory",
  "description": "纯算法长期记忆插件 - 0 API，可选 LLM 增强",
  "version": "1.2.0",
  "kind": "memory",
  "homepage": "https://github.com/xcqblue/algo-memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "autoCapture": { "type": "boolean", "default": true },
      "autoRecall": { "type": "boolean", "default": true },
      "maxResults": { "type": "number", "default": 5 },
      "cleanupDays": { "type": "number", "default": 180 },
      "recencyDecay": { "type": "boolean", "default": true },
      "recencyHalfLife": { "type": "number", "default": 180 },
      "smartDedup": { "type": "boolean", "default": true },
      "dedupThreshold": { "type": "number", "default": 0.85 },
      "coreKeywords": { "type": "array", "items": { "type": "string" } },
      "noiseFilter": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "skipGreetings": { "type": "boolean" }, "skipCommands": { "type": "boolean" } } },
      "adaptiveRetrieval": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "minQueryLength": { "type": "number" } } },
      "sessionMemory": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "maxSessionItems": { "type": "number" } } },
      "weibullDecay": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "shape": { "type": "number" }, "scale": { "type": "number" } } },
      "scopes": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "defaultScope": { "type": "string" } } },
      "mmr": { "type": "object", "description": "MMR 多样性去重", "properties": { "enabled": { "type": "boolean" }, "threshold": { "type": "number" } } },
      "llm": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "provider": { "type": "string" }, "apiKey": { "type": "string" }, "model": { "type": "string" }, "baseURL": { "type": "string" } } },
      "threshold": { "type": "object", "properties": { "useLlmForCore": { "type": "boolean" }, "useLlmForExtract": { "type": "boolean" }, "useLlmForDedup": { "type": "boolean" }, "minConfidence": { "type": "number" } } }
    }
  },
  "requirements": { "node": ">=18.0.0", "openclaw": ">=2026.2.0" }
}
