{
  "id": "algo-memory",
  "name": "algo-memory",
  "description": "纯算法长期记忆插件 - 0 API，可选 LLM 增强",
  "version": "1.3.0",
  "kind": "memory",
  "homepage": "https://github.com/xcqblue/algo-memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "autoCapture": { "type": "boolean", "default": true },
      "autoRecall": { "type": "boolean", "default": true },
      "maxResults": { "type": "number", "default": 5 },
      "cleanupDays": { "type": "number", "default": 180 },
      "recencyDecay": { "type": "boolean", "default": true },
      "recencyHalfLife": { "type": "number", "default": 180 },
      "smartDedup": { "type": "boolean", "default": true },
      "dedupThreshold": { "type": "number", "default": 0.85 },
      "coreKeywords": { "type": "array", "items": { "type": "string" } },
      "noiseFilter": { "type": "object", "properties": { "enabled": {}, "skipGreetings": {}, "skipCommands": {} } },
      "adaptiveRetrieval": { "type": "object", "description": "强制关键词 + CJK阈值", "properties": { "enabled": {}, "minQueryLength": {}, "forceKeywords": { "type": "array", "items": { "type": "string" } } } },
      "sessionMemory": { "type": "object", "properties": { "enabled": {}, "maxSessionItems": {} } },
      "weibullDecay": { "type": "object", "properties": { "enabled": {}, "shape": {}, "scale": {} } },
      "reinforcement": { "type": "object", "description": "访问强化", "properties": { "enabled": {}, "factor": {}, "maxMultiplier": {} } },
      "mmr": { "type": "object", "properties": { "enabled": {}, "threshold": {} } },
      "lengthNorm": { "type": "object", "description": "长度归一化", "properties": { "enabled": {}, "anchor": {} } },
      "hardMinScore": { "type": "object", "description": "硬最低分", "properties": { "enabled": {}, "threshold": {} } },
      "tier": { "type": "object", "description": "三层晋升", "properties": { "enabled": {}, "coreThreshold": {}, "peripheralThreshold": {}, "ageDays": {} } },
      "scopes": { "type": "object", "properties": { "enabled": {}, "defaultScope": {} } },
      "llm": { "type": "object", "properties": { "enabled": {}, "provider": {}, "apiKey": {}, "model": {}, "baseURL": {} } },
      "threshold": { "type": "object", "properties": { "useLlmForCore": {}, "useLlmForExtract": {}, "useLlmForDedup": {}, "minConfidence": {} } }
    }
  },
  "requirements": { "node": ">=18.0.0", "openclaw": ">=2026.2.0" }
}
