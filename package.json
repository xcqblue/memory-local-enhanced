{
  "name": "algo-memory",
  "version": "1.0.0",
  "description": "纯算法长期记忆插件 - 0 API / 可选 LLM 增强",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "npm rebuild better-sqlite3",
    "algo": "node cli.cjs"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "long-term-memory",
    "algo"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "lru-cache": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "openclaw": {
    "id": "algo-memory",
    "extensions": [
      "./src/index.ts"
    ],
    "installDependencies": true
  },
  "bin": {
    "algo-memory": "./cli.cjs"
  }
}