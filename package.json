{
  "name": "algo-memory",
  "version": "2.2.1",
  "description": "纯算法长期记忆插件 - 默认启用LLM / 支持多模型",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node -e \"const fs=require('fs');const s=fs.readFileSync('node_modules/sql.js/dist/sql-wasm.wasm');fs.writeFileSync('dist/sql-wasm.wasm',s);\"",
    "algo": "node cli.cjs"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "long-term-memory",
    "algo"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
    "lru-cache": "^7.18.3",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "openclaw": {
    "id": "algo-memory",
    "extensions": [
      "./dist/index.js"
    ],
    "installDependencies": true
  },
  "bin": {
    "algo-memory": "./cli.cjs"
  }
}
